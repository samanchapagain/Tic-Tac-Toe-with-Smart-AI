<Window x:Class="Tictactoe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tictactoe"
        mc:Ignorable="d"
        Title="TicTacToe" Height="500" Width="800">
    <Canvas Background="#FF9EB4E0">
        <GroupBox Height="120" Header="Stats" Width="244" Canvas.Left="476" Canvas.Top="30">
            <StackPanel>
                <Label x:Name="lblP1Wins" Content="Player 1 Wins: 0" />
                <Label x:Name="lblP2Wins" Content="Player 2 Wins: 0" />
                <Label x:Name="lblTies" Content="Ties: 0" />
            </StackPanel>
        </GroupBox>

        <GroupBox Height="80" Header="Game Status" Width="360" Canvas.Left="36" Canvas.Top="360">
            <Label x:Name="lblStatus" Content="Click Start to begin." FontSize="16" Height="40" />
        </GroupBox>

        <Label x:Name="lbl00" Content="" Canvas.Left="19"  Canvas.Top="10"  FontSize="75" Width="90" Height="100"
               Background="LightGray" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="0"
               MouseLeftButtonDown="PlayerMoveClick"/>
        <Label x:Name="lbl01" Content="" Canvas.Left="116" Canvas.Top="10"  FontSize="75" Width="90" Height="100"
               Background="LightGray" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="0"
               MouseLeftButtonDown="PlayerMoveClick"/>
        <Label x:Name="lbl02" Content="" Canvas.Left="213" Canvas.Top="10"  FontSize="75" Width="90" Height="100"
               Background="LightGray" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="0"
               MouseLeftButtonDown="PlayerMoveClick"/>

        <Label x:Name="lbl10" Content="" Canvas.Left="19"  Canvas.Top="124" FontSize="75" Width="90" Height="100"
               Background="LightGray" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="0"
               MouseLeftButtonDown="PlayerMoveClick"/>
        <Label x:Name="lbl11" Content="" Canvas.Left="116" Canvas.Top="124" FontSize="75" Width="90" Height="100"
               Background="LightGray" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="0"
               MouseLeftButtonDown="PlayerMoveClick"/>
        <Label x:Name="lbl12" Content="" Canvas.Left="213" Canvas.Top="124" FontSize="75" Width="90" Height="100"
               Background="LightGray" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="0"
               MouseLeftButtonDown="PlayerMoveClick"/>

        <Label x:Name="lbl20" Content="" Canvas.Left="19"  Canvas.Top="230" FontSize="75" Width="90" Height="100"
               Background="LightGray" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="0"
               MouseLeftButtonDown="PlayerMoveClick"/>
        <Label x:Name="lbl21" Content="" Canvas.Left="116" Canvas.Top="230" FontSize="75" Width="90" Height="100"
               Background="LightGray" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="0"
               MouseLeftButtonDown="PlayerMoveClick"/>
        <Label x:Name="lbl22" Content="" Canvas.Left="213" Canvas.Top="230" FontSize="75" Width="90" Height="100"
               Background="LightGray" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="0"
               MouseLeftButtonDown="PlayerMoveClick"/>

        <Button x:Name="cmdStart" Content="Start Game" Canvas.Left="538" Canvas.Top="174" Width="120" Height="35" Click="cmdStart_Click"/>
        <CheckBox x:Name="chkVsComputer" Content="Play with Computer (Player 2)" Canvas.Left="510" Canvas.Top="227"/>
    </Canvas>
</Window>